---
现有日历事件

<calendar_variables_display>
<%_ {
  // 1. 获取全量数据 (确保基础对象存在)
  const data = getMessageVar('stat_data', { defaults: {} });
  const rootPath = 'stat_data.事件.日历';

  // 2. 初始化逻辑：确保“事件.日历”及其分类桶存在且为对象
  if (!_.isObject(_.get(data, '事件.日历'))) {
    setMessageVar(rootPath, { 临时: {}, 重复: {} });
  } else {
    if (!_.isObject(_.get(data, '事件.日历.临时'))) {
    setMessageVar(`${rootPath}.临时`, {});
    }
    if (!_.isObject(_.get(data, '事件.日历.重复'))) {
    setMessageVar(`${rootPath}.重复`, {});
    }
  }

  // 3. 提取日历模块数据用于展示
  const calendar = getMessageVar(rootPath, { defaults: { 临时: {}, 重复: {} } });

  // 4. 构建展示用的对象 (严格对应 variables_update_rules 定义的路径)
  const displayOutput = {
    事件:{
      日历: {
        临时: calendar.临时,
        重复: calendar.重复
      }
    }
  };
_%>
<%= YAML.stringify(displayOutput, { blockQuote: 'literal' }) _%>
<%_ } _%>
</calendar_variables_display>
